{
  "name": "n8n-nodes-docx",
  "version": "0.1.0",
  "description": "Convert documents (Word, Excel, Markdown, PDF) to/from each other. Includes an n8n community node and a reusable conversion library powered by LibreOffice headless.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "docx",
    "pdf",
    "xlsx",
    "markdown",
    "convert",
    "libreoffice"
  ],
  "license": "MIT",
  "homepage": "https://github.com/zuse/n8n-nodes-docx",
  "author": {
    "name": "DocX"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zuse/n8n-nodes-docx.git"
  },
  "engines": {
    "node": ">=18.10"
  },
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "lint": "tsc --noEmit",
    "test": "node --test dist/test/*.test.js"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "nodes": [
      "dist/nodes/Docx/Docx.node.js"
    ]
  },
  "dependencies": {
    "marked": "^12.0.2",
    "turndown": "^7.1.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/turndown": "^5.0.4",
    "n8n-workflow": "^1.40.0",
    "typescript": "^5.4.5"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "peerDependenciesMeta": {
    "n8n-workflow": {
      "optional": true
    }
  }
}
