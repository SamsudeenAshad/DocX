{
  "name": "n8n-nodes-docx",
  "version": "0.1.1",
  "description": "Convert documents (Word, Excel, Markdown, PDF) to/from each other. Includes an n8n community node and a reusable conversion library powered by LibreOffice headless.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "docx",
    "pdf",
    "xlsx",
    "markdown",
    "convert",
    "libreoffice"
  ],
  "license": "MIT",
  "homepage": "https://github.com/SamsudeenAshad/DocX#readme",
  "author": {
    "name": "Samsudeen Ashad"
  },
  "bugs": {
    "url": "https://github.com/SamsudeenAshad/DocX/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SamsudeenAshad/DocX.git"
  },
  "engines": {
    "node": ">=18.10"
  },
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "scripts": {
    "build": "tsc && npm run build:icons",
    "build:icons": "mkdir -p dist/nodes/Docx && cp nodes/Docx/*.svg dist/nodes/Docx/",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "lint": "tsc --noEmit",
    "pretest": "tsc -p tsconfig.test.json",
    "test": "node --test dist/test/*.test.js"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "nodes": [
      "dist/nodes/Docx/Docx.node.js"
    ]
  },
  "dependencies": {
    "docx": "^9.7.1",
    "html-to-text": "^10.0.0",
    "mammoth": "^1.12.0",
    "marked": "^12.0.2",
    "pdf-parse": "^2.4.5",
    "pdfmake": "^0.3.11",
    "turndown": "^7.1.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/html-to-text": "^9.0.4",
    "@types/node": "^20.11.30",
    "@types/pdfmake": "^0.3.3",
    "@types/turndown": "^5.0.4",
    "n8n-workflow": "^1.40.0",
    "typescript": "^5.4.5"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "peerDependenciesMeta": {
    "n8n-workflow": {
      "optional": true
    }
  }
}
